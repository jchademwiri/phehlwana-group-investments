---
/**
 * ServiceLayout - shared shell for all 5 individual service pages.
 */

import Layout from '@/layouts/Layout.astro';
import ContactCTA from '@/components/sections/ContactCTA.astro';
import Picture from '@/components/shared/Picture.astro';

interface Props {
  title: string;
  description: string;
  label: string;
  subtitle: string;
  image: string;
  imageAlt: string;
  serviceParam: string;
}

const { title, description, label, subtitle, image, imageAlt, serviceParam } =
  Astro.props;
---

<Layout
  title={`${title} | Phehlwana Group Investments`}
  description={description}
>
  <!-- ── Hero - image background with gradient overlay ────────────────────── -->
  <section
    class='relative min-h-[320px] lg:min-h-[380px] flex items-end overflow-hidden'
  >
    <div class='absolute inset-0'>
      <Picture
        src={image}
        alt=''
        width={1280}
        height={380}
        loading='eager'
        decoding='async'
        class='w-full h-full object-cover'
      />
      <div
        class='absolute inset-0 bg-linear-to-t from-background/95 via-background/60 to-background/30'
      >
      </div>
    </div>

    <div class='relative z-10 w-full pb-10 pt-36 lg:pb-12 lg:pt-44'>
      <div class='container mx-auto px-4'>
        <!-- Breadcrumb -->
        <nav aria-label='Breadcrumb' class='mb-5'>
          <ol class='flex items-center gap-1.5 text-xs text-muted-foreground'>
            <li>
              <a href='/' class='hover:text-foreground transition-colors'
                >Home</a
              >
            </li>
            <li aria-hidden='true'>
              <svg
                xmlns='http://www.w3.org/2000/svg'
                class='size-3'
                viewBox='0 0 24 24'
                fill='none'
                stroke='currentColor'
                stroke-width='2.5'
                stroke-linecap='round'
                stroke-linejoin='round'><path d='m9 18 6-6-6-6'></path></svg
              >
            </li>
            <li>
              <a
                href='/services'
                class='hover:text-foreground transition-colors'>Services</a
              >
            </li>
            <li aria-hidden='true'>
              <svg
                xmlns='http://www.w3.org/2000/svg'
                class='size-3'
                viewBox='0 0 24 24'
                fill='none'
                stroke='currentColor'
                stroke-width='2.5'
                stroke-linecap='round'
                stroke-linejoin='round'><path d='m9 18 6-6-6-6'></path></svg
              >
            </li>
            <li class='text-foreground font-medium' aria-current='page'>
              {title}
            </li>
          </ol>
        </nav>

        <p
          class='text-sm font-semibold text-primary uppercase tracking-widest mb-2'
        >
          {label}
        </p>
        <h1
          class='text-3xl sm:text-4xl font-bold text-foreground leading-tight mb-3 max-w-2xl'
        >
          {title}
        </h1>
        <p class='text-muted-foreground max-w-xl leading-relaxed'>
          {subtitle}
        </p>
      </div>
    </div>
  </section>

  <!-- ── Service content ──────────────────────────────────────────────────── -->
  <div class='container mx-auto px-4 py-12'>
    <slot />
  </div>

  <!-- ── Safety commitment ────────────────────────────────────────────────── -->
  <section class='bg-accent/40 border-y border-border py-12'>
    <div class='container mx-auto px-4'>
      <div class='grid md:grid-cols-[1fr_auto] gap-8 items-start' data-animate>
        <div>
          <p
            class='text-sm font-semibold text-primary uppercase tracking-widest mb-2'
          >
            Health &amp; Safety
          </p>
          <h2 class='text-xl font-bold text-foreground mb-3'>
            Safety is Non-Negotiable
          </h2>
          <p class='text-muted-foreground leading-relaxed text-sm max-w-xl'>
            At Phehlwana Group, the health and safety of our employees, clients,
            and the public is our highest priority. We operate in full
            compliance with the Occupational Health and Safety Act (OHS Act 85
            of 1993) and maintain a zero-harm culture across all our operations.
          </p>
        </div>
        <ul class='space-y-2 shrink-0'>
          {
            [
              'Dedicated safety officer on every project site',
              'Daily toolbox talks and safety briefings',
              'Full PPE provision for all workers',
              'Formal risk assessments before high-risk activities',
              'Incident reporting and investigation procedures',
              'Regular safety audits throughout project duration',
            ].map((item) => (
              <li class='flex items-center gap-2.5 text-sm text-muted-foreground'>
                <svg
                  xmlns='http://www.w3.org/2000/svg'
                  class='size-4 text-primary shrink-0'
                  viewBox='0 0 24 24'
                  fill='none'
                  stroke='currentColor'
                  stroke-width='2.5'
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  aria-hidden='true'
                >
                  <polyline points='20 6 9 17 4 12' />
                </svg>
                {item}
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>

  <ContactCTA
    heading='Ready to Get Started?'
    body='Contact us today for a free, no-obligation quote. Our team responds within 1 business day.'
    btnLabel='Request a Quote'
    btnHref={`/contact?service=${encodeURIComponent(serviceParam)}`}
  />
</Layout>
