---
/**
 * ContactCTA - reusable bottom call-to-action strip
 *
 * Props:
 *   heading?  - override the default heading
 *   body?     - override the default body text
 *   btnLabel? - override the button label
 *   btnHref?  - override the button href (default: /contact)
 */

interface Props {
  heading?: string;
  body?: string;
  btnLabel?: string;
  btnHref?: string;
}

const {
  heading = 'Have a project in mind?',
  body = 'Contact us for a free, no-obligation quote. We respond within 1 business day.',
  btnLabel = 'Request a Quote',
  btnHref = '/contact',
} = Astro.props;
---

<section class='bg-accent/40 border-t border-border py-14'>
  <div class='container mx-auto px-4 text-center'>
    <h2 class='text-2xl font-bold text-foreground mb-3'>{heading}</h2>
    <p class='text-muted-foreground mb-6 max-w-md mx-auto text-sm'>
      {body}
    </p>
    <a
      href={btnHref}
      data-track="cta"
      data-track-label={btnLabel}
      class='inline-flex items-center gap-2 bg-primary text-primary-foreground font-semibold px-6 py-3 rounded-lg text-sm hover:bg-primary/90 transition-colors'
    >
      {btnLabel}
      <svg
        xmlns='http://www.w3.org/2000/svg'
        class='size-4'
        viewBox='0 0 24 24'
        fill='none'
        stroke='currentColor'
        stroke-width='2'
        stroke-linecap='round'
        stroke-linejoin='round'
        aria-hidden='true'
        ><path d='M5 12h14'></path><path d='m12 5 7 7-7 7'></path></svg
      >
    </a>
  </div>
</section>
