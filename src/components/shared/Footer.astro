---
import {
  quickLinks,
  serviceLinks,
  legalLinks,
  developer,
} from '@/data/navigation';

const currentYear = new Date().getFullYear();
---

<footer class='bg-background text-foreground'>
  <div class='container mx-auto px-4 py-16'>
    <div class='grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10'>
      <!-- Column 1: Brand -->
      <div class='lg:col-span-1'>
        <a
          href='/'
          class='flex items-center gap-3 mb-5'
          aria-label='Phehlwana Group Investments - Home'
        >
          <img
            src='/img/logo.png'
            alt='Phehlwana Group Investments logo'
            width='48'
            height='48'
            class='size-12 object-contain block dark:hidden'
          />
          <img
            src='/img/logow.png'
            alt='Phehlwana Group Investments logo'
            width='48'
            height='48'
            class='size-12 object-contain hidden dark:block'
          />
          <div class='leading-tight'>
            <span class='block font-bold text-foreground text-base'
              >Phehlwana Group</span
            >
            <span class='block text-xs text-muted-foreground'>Investments</span>
          </div>
        </a>
        <p class='text-sm text-muted-foreground leading-relaxed mb-6'>
          A Pretoria-based construction and maintenance company delivering
          quality service across civil engineering, mechanical engineering,
          cleaning, and plant hire since 2015.
        </p>
        <div class='flex items-center gap-3'>
          <!-- Inactive social links commented out to avoid empty anchor clicks
          <a
            href='#'
            aria-label='Follow us on Facebook'
            class='size-9 rounded-md bg-accent flex items-center justify-center text-muted-foreground hover:bg-primary hover:text-primary-foreground transition-colors'
          >
            <svg
              xmlns='http://www.w3.org/2000/svg'
              class='size-4'
              viewBox='0 0 24 24'
              fill='currentColor'
              aria-hidden='true'
              ><path
                d='M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z'
              ></path></svg
            >
          </a>
          <a
            href='#'
            aria-label='Follow us on Instagram'
            class='size-9 rounded-md bg-accent flex items-center justify-center text-muted-foreground hover:bg-primary hover:text-primary-foreground transition-colors'
          >
            <svg
              xmlns='http://www.w3.org/2000/svg'
              class='size-4'
              viewBox='0 0 24 24'
              fill='none'
              stroke='currentColor'
              stroke-width='2'
              stroke-linecap='round'
              stroke-linejoin='round'
              aria-hidden='true'
              ><rect width='20' height='20' x='2' y='2' rx='5' ry='5'
              ></rect><path d='M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z'
              ></path><line x1='17.5' x2='17.51' y1='6.5' y2='6.5'></line></svg
            >
          </a>
          <a
            href='#'
            aria-label='Connect on LinkedIn'
            class='size-9 rounded-md bg-accent flex items-center justify-center text-muted-foreground hover:bg-primary hover:text-primary-foreground transition-colors'
          >
            <svg
              xmlns='http://www.w3.org/2000/svg'
              class='size-4'
              viewBox='0 0 24 24'
              fill='currentColor'
              aria-hidden='true'
              ><path
                d='M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z'
              ></path><rect width='4' height='12' x='2' y='9'></rect><circle
                cx='4'
                cy='4'
                r='2'></circle></svg
            >
          </a>
          -->
          <a
            href='https://wa.me/27792947635'
            target='_blank'
            rel='noopener noreferrer'
            aria-label='Chat on WhatsApp'
            class='size-9 rounded-md bg-accent flex items-center justify-center text-muted-foreground hover:bg-primary hover:text-primary-foreground transition-colors'
          >
            <svg
              xmlns='http://www.w3.org/2000/svg'
              class='size-4'
              viewBox='0 0 24 24'
              fill='currentColor'
              aria-hidden='true'
              ><path
                d='M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z'
              ></path></svg
            >
          </a>
        </div>
      </div>

      <!-- Column 2: Quick Links -->
      <div>
        <h3
          class='text-foreground font-semibold text-sm uppercase tracking-wider mb-5'
        >
          Quick Links
        </h3>
        <ul class='space-y-2.5'>
          {
            quickLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class='text-sm text-muted-foreground hover:text-foreground transition-colors flex items-center gap-2 group'
                >
                  <svg
                    xmlns='http://www.w3.org/2000/svg'
                    class='size-3 text-primary shrink-0 transition-transform group-hover:translate-x-0.5'
                    viewBox='0 0 24 24'
                    fill='none'
                    stroke='currentColor'
                    stroke-width='2.5'
                    stroke-linecap='round'
                    stroke-linejoin='round'
                    aria-hidden='true'
                  >
                    <path d='m9 18 6-6-6-6' />
                  </svg>
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Column 3: Services -->
      <div>
        <h3
          class='text-foreground font-semibold text-sm uppercase tracking-wider mb-5'
        >
          Our Services
        </h3>
        <ul class='space-y-2.5'>
          {
            serviceLinks.map((service) => (
              <li>
                <a
                  href={service.href}
                  class='text-sm text-muted-foreground hover:text-foreground transition-colors flex items-center gap-2 group'
                >
                  <svg
                    xmlns='http://www.w3.org/2000/svg'
                    class='size-3 text-primary shrink-0 transition-transform group-hover:translate-x-0.5'
                    viewBox='0 0 24 24'
                    fill='none'
                    stroke='currentColor'
                    stroke-width='2.5'
                    stroke-linecap='round'
                    stroke-linejoin='round'
                    aria-hidden='true'
                  >
                    <path d='m9 18 6-6-6-6' />
                  </svg>
                  {service.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Column 4: Contact -->
      <div>
        <h3
          class='text-foreground font-semibold text-sm uppercase tracking-wider mb-5'
        >
          Get In Touch
        </h3>
        <ul class='space-y-4'>
          <li class='flex items-start gap-3'>
            <div
              class='size-8 rounded-md bg-primary/20 flex items-center justify-center shrink-0 mt-0.5'
            >
              <svg
                xmlns='http://www.w3.org/2000/svg'
                class='size-4 text-primary'
                viewBox='0 0 24 24'
                fill='none'
                stroke='currentColor'
                stroke-width='2'
                stroke-linecap='round'
                stroke-linejoin='round'
                aria-hidden='true'
                ><path d='M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z'
                ></path><circle cx='12' cy='10' r='3'></circle></svg
              >
            </div>
            <div>
              <p
                class='text-xs text-muted-foreground uppercase tracking-wide mb-0.5'
              >
                Address
              </p>
              <p class='text-sm text-foreground/80 leading-relaxed'>
                Office No 06, PKN Office Park,<br />
                62 Taaifontein Street,<br />
                Montana Park, 0182
              </p>
            </div>
          </li>
          <li class='flex items-start gap-3'>
            <div
              class='size-8 rounded-md bg-primary/20 flex items-center justify-center shrink-0 mt-0.5'
            >
              <svg
                xmlns='http://www.w3.org/2000/svg'
                class='size-4 text-primary'
                viewBox='0 0 24 24'
                fill='none'
                stroke='currentColor'
                stroke-width='2'
                stroke-linecap='round'
                stroke-linejoin='round'
                aria-hidden='true'
                ><path
                  d='M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.06 6.06l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z'
                ></path></svg
              >
            </div>
            <div>
              <p
                class='text-xs text-muted-foreground uppercase tracking-wide mb-0.5'
              >
                Phone
              </p>
              <a
                href='tel:+27126550284'
                class='text-sm text-foreground/80 hover:text-foreground transition-colors block'
                >012 655 0284</a
              >
              <a
                href='tel:+27792947635'
                class='text-sm text-foreground/80 hover:text-foreground transition-colors block'
                >079 294 7635</a
              >
            </div>
          </li>
          <li class='flex items-start gap-3'>
            <div
              class='size-8 rounded-md bg-primary/20 flex items-center justify-center shrink-0 mt-0.5'
            >
              <svg
                xmlns='http://www.w3.org/2000/svg'
                class='size-4 text-primary'
                viewBox='0 0 24 24'
                fill='none'
                stroke='currentColor'
                stroke-width='2'
                stroke-linecap='round'
                stroke-linejoin='round'
                aria-hidden='true'
                ><rect width='20' height='16' x='2' y='4' rx='2'></rect><path
                  d='m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7'></path></svg
              >
            </div>
            <div>
              <p
                class='text-xs text-muted-foreground uppercase tracking-wide mb-0.5'
              >
                Email
              </p>
              <a
                href='mailto:info@phehlwanagroup.co.za'
                class='text-sm text-foreground/80 hover:text-foreground transition-colors'
              >
                info@phehlwanagroup.co.za
              </a>
            </div>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class='border-t border-border'>
    <div class='container mx-auto px-4 py-5'>
      <div
        class='flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-muted-foreground'
      >
        <p>
          &copy; {currentYear}
          <a
            href='/'
            class='text-foreground/70 hover:text-foreground transition-colors font-medium'
            >Phehlwana Group Investments</a
          >. All rights reserved.
        </p>
        <div class='flex flex-wrap items-center gap-4'>
          {
            legalLinks.map((link, i) => (
              <>
                {i > 0 && <span aria-hidden='true'>·</span>}
                <a
                  href={link.href}
                  class='hover:text-foreground transition-colors'
                >
                  {link.label}
                </a>
              </>
            ))
          }
          <span aria-hidden='true'>·</span>
          <span>
            Developed by{' '}
            <a
              href={developer.href}
              target='_blank'
              rel='noopener noreferrer'
              class='text-foreground/70 hover:text-foreground transition-colors font-medium'
            >
              {developer.name}
            </a>
          </span>
        </div>
      </div>
    </div>
  </div>
</footer>
