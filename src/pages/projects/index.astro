---
import { getCollection } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import Picture from '@/components/shared/Picture.astro';

export const prerender = true;

const allProjects = await getCollection('projects', ({ data }) => data.published);

// Sort: featured first, then by year descending
const projects = allProjects.sort((a, b) => {
    if (a.data.featured && !b.data.featured) return -1;
    if (!a.data.featured && b.data.featured) return 1;
    return b.data.year - a.data.year;
});

const categories = ['All', 'Construction', 'Road', 'Mechanical', 'Cleaning', 'Plant Hire'] as const;

const categoryColours: Record<string, string> = {
    Construction: 'bg-blue-100 text-blue-800 dark:bg-blue-900/40 dark:text-blue-300',
    Road:         'bg-amber-100 text-amber-800 dark:bg-amber-900/40 dark:text-amber-300',
    Mechanical:   'bg-purple-100 text-purple-800 dark:bg-purple-900/40 dark:text-purple-300',
    Cleaning:     'bg-green-100 text-green-800 dark:bg-green-900/40 dark:text-green-300',
    'Plant Hire': 'bg-orange-100 text-orange-800 dark:bg-orange-900/40 dark:text-orange-300',
};
---

<Layout
    title='Our Projects'
    description='Browse completed construction, civil engineering, road, cleaning and plant hire projects by Phehlwana Group Investments across Pretoria and Gauteng.'
>
    <!-- Page header -->
    <section class='bg-accent/40 border-b border-border pt-36 pb-14 lg:pt-44'>
        <div class='container mx-auto px-4'>
            <p class='text-sm font-semibold text-primary uppercase tracking-widest mb-2'>
                Our Work
            </p>
            <h1 class='text-4xl font-bold text-foreground mb-3'>Project Portfolio</h1>
            <p class='text-muted-foreground max-w-xl'>
                A selection of completed projects across construction, road maintenance,
                cleaning, and plant hire - delivered across Pretoria and Gauteng.
            </p>
        </div>
    </section>

    <!-- Filter + grid -->
    <section class='container mx-auto px-4 py-14'>

        <!-- Category filter -->
        <div
            class='flex flex-wrap gap-2 mb-10'
            role='group'
            aria-label='Filter projects by category'
            id='category-filters'
        >
            {categories.map((cat) => (
                <button
                    type='button'
                    data-filter={cat}
                    class:list={[
                        'filter-btn px-4 py-1.5 rounded-full text-sm font-medium border transition-colors',
                        cat === 'All'
                            ? 'bg-primary text-primary-foreground border-primary'
                            : 'bg-background text-muted-foreground border-border hover:border-primary hover:text-foreground',
                    ]}
                    aria-pressed={cat === 'All' ? 'true' : 'false'}
                >
                    {cat}
                </button>
            ))}
        </div>

        <!-- Projects grid -->
        <div
            class='grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6'
            id='projects-grid'
        >
            {projects.map((project) => (
                <article
                    class='project-card group relative bg-card ring-1 ring-border rounded-xl overflow-hidden flex flex-col transition-shadow hover:shadow-lg'
                    data-category={project.data.category}
                >
                    <!-- Full-card link -->
                    <a
                        href={`/projects/${project.id}`}
                        class='absolute inset-0 z-10'
                        aria-label={`View project: ${project.data.title}`}
                    />

                    <!-- Cover image -->
                    <div class='aspect-16/10 overflow-hidden bg-accent'>
                        <Picture
                            src={project.data.coverImage ?? '/images/placeholder.svg'}
                            alt=''
                            width={640}
                            height={400}
                            loading='lazy'
                            decoding='async'
                            class='w-full h-full object-cover transition-transform duration-500 group-hover:scale-105'
                        />
                    </div>

                    <!-- Content -->
                    <div class='flex flex-col flex-1 p-5 gap-3'>
                        <!-- Category + year -->
                        <div class='flex items-center justify-between gap-2'>
                            <span class:list={[
                                'inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold',
                                categoryColours[project.data.category] ?? 'bg-muted text-muted-foreground',
                            ]}>
                                {project.data.category}
                            </span>
                            <span class='text-xs text-muted-foreground'>{project.data.year}</span>
                        </div>

                        <!-- Title -->
                        <h2 class='text-base font-semibold text-foreground leading-snug group-hover:text-primary transition-colors'>
                            {project.data.title}
                        </h2>

                        <!-- Location + view arrow -->
                        <div class='flex items-center justify-between gap-2 mt-auto'>
                            <p class='text-sm text-muted-foreground flex items-center gap-1.5'>
                                <svg
                                    xmlns='http://www.w3.org/2000/svg'
                                    class='size-3.5 text-primary shrink-0'
                                    viewBox='0 0 24 24'
                                    fill='none'
                                    stroke='currentColor'
                                    stroke-width='2'
                                    stroke-linecap='round'
                                    stroke-linejoin='round'
                                    aria-hidden='true'
                                >
                                    <path d='M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z'/>
                                    <circle cx='12' cy='10' r='3'/>
                                </svg>
                                {project.data.location}
                            </p>
                            <span class='text-xs font-medium text-primary flex items-center gap-1 shrink-0'>
                                View
                                <svg xmlns='http://www.w3.org/2000/svg' class='size-3' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true'><path d='m9 18 6-6-6-6'/></svg>
                            </span>
                        </div>
                    </div>
                </article>
            ))}
        </div>

        <!-- Empty state (shown by JS when filter has no results) -->
        <p
            id='no-results'
            class='hidden text-center text-muted-foreground py-16 text-sm'
            aria-live='polite'
        >
            No projects found in this category.
        </p>
    </section>

    <!-- CTA -->
    <section class='bg-accent/40 border-t border-border py-14'>
        <div class='container mx-auto px-4 text-center'>
            <h2 class='text-2xl font-bold text-foreground mb-3'>Have a project in mind?</h2>
            <p class='text-muted-foreground mb-6 max-w-md mx-auto text-sm'>
                Contact us for a free, no-obligation quote. We respond within 1 business day.
            </p>
            <a
                href='/contact'
                class='inline-flex items-center gap-2 bg-primary text-primary-foreground font-semibold px-6 py-3 rounded-lg text-sm hover:bg-primary/90 transition-colors'
            >
                Request a Quote
                <svg xmlns='http://www.w3.org/2000/svg' class='size-4' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true'><path d='M5 12h14'/><path d='m12 5 7 7-7 7'/></svg>
            </a>
        </div>
    </section>
</Layout>

<script>
    const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
    const cards   = document.querySelectorAll<HTMLElement>('.project-card');
    const noResults = document.getElementById('no-results');

    buttons.forEach((btn) => {
        btn.addEventListener('click', () => {
            const filter = btn.dataset.filter ?? 'All';

            // Update button states
            buttons.forEach((b) => {
                const active = b.dataset.filter === filter;
                b.setAttribute('aria-pressed', String(active));
                b.classList.toggle('bg-primary',               active);
                b.classList.toggle('text-primary-foreground',  active);
                b.classList.toggle('border-primary',           active);
                b.classList.toggle('bg-background',            !active);
                b.classList.toggle('text-muted-foreground',    !active);
                b.classList.toggle('border-border',            !active);
            });

            // Show / hide cards
            let visible = 0;
            cards.forEach((card) => {
                const match = filter === 'All' || card.dataset.category === filter;
                card.style.display = match ? '' : 'none';
                if (match) visible++;
            });

            noResults?.classList.toggle('hidden', visible > 0);
        });
    });
</script>
