---
import { getCollection, render } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import Picture from '@/components/shared/Picture.astro';

export const prerender = true;

export async function getStaticPaths() {
  const projects = await getCollection(
    'projects',
    ({ data }) => data.published,
  );
  return projects.map((project) => ({
    params: { id: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);

const categoryColours: Record<string, { badge: string; dot: string }> = {
  Construction: {
    badge: 'bg-blue-100 text-blue-800 dark:bg-blue-900/40 dark:text-blue-300',
    dot: 'bg-blue-500',
  },
  Road: {
    badge:
      'bg-amber-100 text-amber-800 dark:bg-amber-900/40 dark:text-amber-300',
    dot: 'bg-amber-500',
  },
  Mechanical: {
    badge:
      'bg-purple-100 text-purple-800 dark:bg-purple-900/40 dark:text-purple-300',
    dot: 'bg-purple-500',
  },
  Cleaning: {
    badge:
      'bg-green-100 text-green-800 dark:bg-green-900/40 dark:text-green-300',
    dot: 'bg-green-500',
  },
  'Plant Hire': {
    badge:
      'bg-orange-100 text-orange-800 dark:bg-orange-900/40 dark:text-orange-300',
    dot: 'bg-orange-500',
  },
};

const colour = categoryColours[project.data.category] ?? {
  badge: 'bg-muted text-muted-foreground',
  dot: 'bg-muted-foreground',
};

const allImages = [
  project.data.coverImage,
  ...(project.data.images?.slice(1) ?? []),
];
---

<Layout
  title={project.data.title}
  description={project.data.description ??
    `${project.data.category} project by Phehlwana Group Investments - ${project.data.location}, ${project.data.year}.`}
  ogImage={project.data.coverImage}
>
  <!-- ── Hero header ─────────────────────────────────────────────────────── -->
  <section
    class='bg-accent/40 border-b border-border pt-36 pb-14 lg:pt-44 lg:pb-20'
  >
    <div class='container mx-auto px-4'>
      <!-- Breadcrumb -->
      <nav aria-label='Breadcrumb' class='mb-6'>
        <ol class='flex items-center gap-1.5 text-xs text-muted-foreground'>
          <li>
            <a href='/' class='hover:text-foreground transition-colors'>Home</a>
          </li>
          <li aria-hidden='true'>
            <svg
              xmlns='http://www.w3.org/2000/svg'
              class='size-3'
              viewBox='0 0 24 24'
              fill='none'
              stroke='currentColor'
              stroke-width='2.5'
              stroke-linecap='round'
              stroke-linejoin='round'><path d='m9 18 6-6-6-6'></path></svg
            >
          </li>
          <li>
            <a href='/projects' class='hover:text-foreground transition-colors'
              >Projects</a
            >
          </li>
          <li aria-hidden='true'>
            <svg
              xmlns='http://www.w3.org/2000/svg'
              class='size-3'
              viewBox='0 0 24 24'
              fill='none'
              stroke='currentColor'
              stroke-width='2.5'
              stroke-linecap='round'
              stroke-linejoin='round'><path d='m9 18 6-6-6-6'></path></svg
            >
          </li>
          <li class='text-foreground truncate max-w-xs' aria-current='page'>
            {project.data.title}
          </li>
        </ol>
      </nav>

      <!-- Category badge -->
      <div class='mb-4'>
        <span
          class:list={[
            'inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold',
            colour.badge,
          ]}
        >
          <span
            class:list={['size-1.5 rounded-full', colour.dot]}
            aria-hidden='true'></span>
          {project.data.category}
        </span>
      </div>

      <h1
        class='text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground leading-tight mb-6'
      >
        {project.data.title}
      </h1>

      <!-- Meta pills -->
      <div class='flex flex-wrap gap-3'>
        <span
          class='inline-flex items-center gap-2 bg-background border border-border rounded-lg px-3 py-1.5 text-sm text-foreground/80'
        >
          <svg
            xmlns='http://www.w3.org/2000/svg'
            class='size-4 text-primary'
            viewBox='0 0 24 24'
            fill='none'
            stroke='currentColor'
            stroke-width='2'
            stroke-linecap='round'
            stroke-linejoin='round'
            aria-hidden='true'
            ><path d='M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z'
            ></path><circle cx='12' cy='10' r='3'></circle></svg
          >
          {project.data.location}
        </span>
        <span
          class='inline-flex items-center gap-2 bg-background border border-border rounded-lg px-3 py-1.5 text-sm text-foreground/80'
        >
          <svg
            xmlns='http://www.w3.org/2000/svg'
            class='size-4 text-primary'
            viewBox='0 0 24 24'
            fill='none'
            stroke='currentColor'
            stroke-width='2'
            stroke-linecap='round'
            stroke-linejoin='round'
            aria-hidden='true'
            ><rect width='18' height='18' x='3' y='4' rx='2'></rect><path
              d='M16 2v4M8 2v4M3 10h18'></path></svg
          >
          {project.data.duration ?? String(project.data.year)}
        </span>
        {
          project.data.client && (
            <span class='inline-flex items-center gap-2 bg-background border border-border rounded-lg px-3 py-1.5 text-sm text-foreground/80'>
              <svg
                xmlns='http://www.w3.org/2000/svg'
                class='size-4 text-primary'
                viewBox='0 0 24 24'
                fill='none'
                stroke='currentColor'
                stroke-width='2'
                stroke-linecap='round'
                stroke-linejoin='round'
                aria-hidden='true'
              >
                <>
                  <path d='M3 9h18v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V9Z' />
                  <path d='M3 9V7a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v2' />
                </>
              </svg>
              {project.data.client}
            </span>
          )
        }
      </div>
    </div>
  </section>

  <!-- ── Main image + gallery ─────────────────────────────────────────────── -->
  <div class='container mx-auto px-4 mt-8'>
    <!-- Hero image -->
    <div
      class='aspect-16/6 rounded-2xl overflow-hidden bg-accent shadow-sm cursor-zoom-in'
      id='gallery-main'
      role='button'
      tabindex='0'
      aria-label='View full image'
      data-src={project.data.coverImage}
    >
      <img
        id='main-img'
        src={project.data.coverImage ?? '/images/placeholder.svg'}
        alt={project.data.title}
        width='1024'
        height='384'
        loading='eager'
        decoding='async'
        class='w-full h-full object-cover transition-opacity duration-300'
      />
    </div>

    <!-- Thumbnail strip -->
    {
      allImages.length > 1 && (
        <div
          class='flex gap-3 mt-3 overflow-x-auto pb-1'
          role='list'
          aria-label='Project images'
        >
          {allImages.map((img, i) => (
            <button
              type='button'
              class:list={[
                'gallery-thumb shrink-0 w-24 aspect-video rounded-lg overflow-hidden border-2 transition-all focus-visible:outline-2 focus-visible:outline-primary',
                i === 0
                  ? 'border-primary'
                  : 'border-transparent hover:border-primary/50',
              ]}
              data-src={img}
              aria-label={`View image ${i + 1}`}
              role='listitem'
            >
              <img
                src={img}
                alt=''
                width='96'
                height='54'
                loading='lazy'
                decoding='async'
                class='w-full h-full object-cover'
              />
            </button>
          ))}
        </div>
      )
    }

    <!-- Description below images -->
    {
      project.data.description && (
        <p class='mt-5 text-base text-muted-foreground leading-relaxed border-l-2 border-primary pl-4'>
          {project.data.description}
        </p>
      )
    }
  </div>

  <!-- ── Two-column: content + info sidebar ───────────────────────────────── -->
  <div class='container mx-auto px-4 py-12'>
    <div class='lg:grid lg:grid-cols-[1fr_280px] lg:gap-12 items-start'>
      <!-- Project body -->
      <article>
        <div class='prose prose-neutral dark:prose-invert max-w-none prose-lg'>
          <Content />
        </div>
      </article>

      <!-- Info sidebar -->
      <aside class='mt-10 lg:mt-0 sticky top-32 self-start space-y-4'>
        <!-- Project details card -->
        <div class='bg-card border border-border rounded-xl overflow-hidden'>
          <div class='border-b border-border px-5 py-3'>
            <p
              class='text-xs font-semibold text-muted-foreground uppercase tracking-widest'
            >
              Project Details
            </p>
          </div>
          <dl class='divide-y divide-border'>
            {
              project.data.client && (
                <div class='flex items-start gap-3 px-5 py-3.5'>
                  <svg
                    xmlns='http://www.w3.org/2000/svg'
                    class='size-4 text-primary mt-0.5 shrink-0'
                    viewBox='0 0 24 24'
                    fill='none'
                    stroke='currentColor'
                    stroke-width='2'
                    stroke-linecap='round'
                    stroke-linejoin='round'
                    aria-hidden='true'
                  >
                    <>
                      <path d='M3 9h18v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V9Z' />
                      <path d='M3 9V7a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v2' />
                    </>
                  </svg>
                  <div>
                    <dt class='text-xs text-muted-foreground mb-0.5'>Client</dt>
                    <dd class='text-sm font-medium text-foreground'>
                      {project.data.client}
                    </dd>
                  </div>
                </div>
              )
            }
            {
              project.data.projectNo && (
                <div class='flex items-start gap-3 px-5 py-3.5'>
                  <svg
                    xmlns='http://www.w3.org/2000/svg'
                    class='size-4 text-primary mt-0.5 shrink-0'
                    viewBox='0 0 24 24'
                    fill='none'
                    stroke='currentColor'
                    stroke-width='2'
                    stroke-linecap='round'
                    stroke-linejoin='round'
                    aria-hidden='true'
                  >
                    <>
                      <path d='M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z' />
                      <polyline points='14 2 14 8 20 8' />
                    </>
                  </svg>
                  <div>
                    <dt class='text-xs text-muted-foreground mb-0.5'>
                      Project No.
                    </dt>
                    <dd class='text-sm font-medium text-foreground font-mono'>
                      {project.data.projectNo}
                    </dd>
                  </div>
                </div>
              )
            }
            <div class='flex items-start gap-3 px-5 py-3.5'>
              <svg
                xmlns='http://www.w3.org/2000/svg'
                class='size-4 text-primary mt-0.5 shrink-0'
                viewBox='0 0 24 24'
                fill='none'
                stroke='currentColor'
                stroke-width='2'
                stroke-linecap='round'
                stroke-linejoin='round'
                aria-hidden='true'
                ><path d='M2 20h20'></path><path d='M5 20V8l7-5 7 5v12'
                ></path></svg
              >
              <div>
                <dt class='text-xs text-muted-foreground mb-0.5'>Category</dt>
                <dd class='text-sm font-medium text-foreground'>
                  {project.data.category}
                </dd>
              </div>
            </div>
            <div class='flex items-start gap-3 px-5 py-3.5'>
              <svg
                xmlns='http://www.w3.org/2000/svg'
                class='size-4 text-primary mt-0.5 shrink-0'
                viewBox='0 0 24 24'
                fill='none'
                stroke='currentColor'
                stroke-width='2'
                stroke-linecap='round'
                stroke-linejoin='round'
                aria-hidden='true'
                ><path d='M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z'
                ></path><circle cx='12' cy='10' r='3'></circle></svg
              >
              <div>
                <dt class='text-xs text-muted-foreground mb-0.5'>Location</dt>
                <dd class='text-sm font-medium text-foreground'>
                  {project.data.location}
                </dd>
              </div>
            </div>
            <div class='flex items-start gap-3 px-5 py-3.5'>
              <svg
                xmlns='http://www.w3.org/2000/svg'
                class='size-4 text-primary mt-0.5 shrink-0'
                viewBox='0 0 24 24'
                fill='none'
                stroke='currentColor'
                stroke-width='2'
                stroke-linecap='round'
                stroke-linejoin='round'
                aria-hidden='true'
                ><rect width='18' height='18' x='3' y='4' rx='2'></rect><path
                  d='M16 2v4M8 2v4M3 10h18'></path></svg
              >
              <div>
                <dt class='text-xs text-muted-foreground mb-0.5'>
                  Project Duration
                </dt>
                <dd class='text-sm font-medium text-foreground'>
                  {project.data.duration ?? String(project.data.year)}
                </dd>
              </div>
            </div>
          </dl>
        </div>

        <!-- CTA card -->
        <div class='bg-accent border border-border rounded-xl p-5'>
          <p class='font-semibold text-foreground mb-1'>
            Have a similar project?
          </p>
          <p class='text-sm text-muted-foreground mb-4 leading-relaxed'>
            Contact us for a free, no-obligation quote. We respond within 1
            business day.
          </p>
          <a
            href={`/contact?service=${encodeURIComponent(project.data.category)}`}
            class='inline-flex w-full items-center justify-center gap-2 bg-primary text-primary-foreground font-semibold px-4 py-2.5 rounded-lg text-sm hover:bg-primary/90 transition-colors'
          >
            Request a Quote
            <svg
              xmlns='http://www.w3.org/2000/svg'
              class='size-4'
              viewBox='0 0 24 24'
              fill='none'
              stroke='currentColor'
              stroke-width='2'
              stroke-linecap='round'
              stroke-linejoin='round'
              aria-hidden='true'
              ><path d='M5 12h14'></path><path d='m12 5 7 7-7 7'></path></svg
            >
          </a>
        </div>
      </aside>
    </div>
  </div>

  <!-- ── Bottom bar ───────────────────────────────────────────────────────── -->
  <div class='border-t border-border bg-accent/30'>
    <div
      class='container mx-auto px-4 py-8 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4'
    >
      <a
        href='/projects'
        class='inline-flex items-center gap-2 text-sm text-muted-foreground hover:text-foreground transition-colors'
      >
        <svg
          xmlns='http://www.w3.org/2000/svg'
          class='size-4'
          viewBox='0 0 24 24'
          fill='none'
          stroke='currentColor'
          stroke-width='2'
          stroke-linecap='round'
          stroke-linejoin='round'
          aria-hidden='true'
          ><path d='M19 12H5'></path><path d='m12 19-7-7 7-7'></path></svg
        >
        Back to Projects
      </a>
      <a
        href='/contact'
        class='inline-flex items-center gap-2 bg-primary text-primary-foreground font-semibold px-5 py-2.5 rounded-lg text-sm hover:bg-primary/90 transition-colors'
      >
        Request a Quote
        <svg
          xmlns='http://www.w3.org/2000/svg'
          class='size-4'
          viewBox='0 0 24 24'
          fill='none'
          stroke='currentColor'
          stroke-width='2'
          stroke-linecap='round'
          stroke-linejoin='round'
          aria-hidden='true'
          ><path d='M5 12h14'></path><path d='m12 5 7 7-7 7'></path></svg
        >
      </a>
    </div>
  </div>
</Layout>

<script>
  // ── Gallery thumbnail switcher ────────────────────────────────────────────
  const mainImg = document.getElementById(
    'main-img',
  ) as HTMLImageElement | null;
  const thumbs = document.querySelectorAll<HTMLButtonElement>('.gallery-thumb');

  thumbs.forEach((thumb) => {
    thumb.addEventListener('click', () => {
      const src = thumb.dataset.src;
      if (!src || !mainImg) return;

      // Fade out → swap → fade in
      mainImg.style.opacity = '0';
      setTimeout(() => {
        mainImg.src = src;
        mainImg.style.opacity = '1';
      }, 200);

      // Update active border
      thumbs.forEach((t) => {
        t.classList.remove('border-primary');
        t.classList.add('border-transparent');
      });
      thumb.classList.add('border-primary');
      thumb.classList.remove('border-transparent');
    });
  });
</script>
