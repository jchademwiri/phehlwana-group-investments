---
import { getCollection } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import Picture from '@/components/shared/Picture.astro';

export const prerender = true;

const allPosts = await getCollection('blog', ({ data }) => data.published);

// Sort newest first
const posts = allPosts.sort(
    (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);

function formatDate(date: Date): string {
    return date.toLocaleDateString('en-ZA', {
        year: 'numeric',
        month: 'long',
        day: 'numeric',
    });
}
---

<Layout
    title='Blog & News'
    description='Stay up to date with the latest news, project updates, safety insights, and industry articles from Phehlwana Group Investments in Pretoria.'
>
    <!-- Page header -->
    <section class='bg-accent/40 border-b border-border pt-36 pb-14 lg:pt-44'>
        <div class='container mx-auto px-4'>
            <p class='text-sm font-semibold text-primary uppercase tracking-widest mb-2'>
                From the Blog
            </p>
            <h1 class='text-4xl font-bold text-foreground mb-3'>News &amp; Insights</h1>
            <p class='text-muted-foreground max-w-xl'>
                Construction tips, safety guides, industry news, and updates from the
                Phehlwana Group team.
            </p>
        </div>
    </section>

    <!-- Posts grid -->
    <section class='container mx-auto px-4 py-14'>
        {posts.length === 0 ? (
            <p class='text-center text-muted-foreground py-16 text-sm'>
                No posts published yet - check back soon.
            </p>
        ) : (
            <div class='grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6'>
                {posts.map((post) => (
                    <article class='group relative bg-card ring-1 ring-border rounded-xl overflow-hidden flex flex-col transition-shadow hover:shadow-lg'>

                        <!-- Full-card link -->
                        <a
                            href={`/blog/${post.id}`}
                            class='absolute inset-0 z-10'
                            aria-label={`Read: ${post.data.title}`}
                        />

                        <!-- Cover image - always shown, falls back to branded placeholder -->
                        <div class='aspect-video overflow-hidden bg-accent'>
                            <Picture
                                src={post.data.coverImage ?? '/images/placeholder.svg'}
                                alt=''
                                width={640}
                                height={360}
                                loading='lazy'
                                decoding='async'
                                class='w-full h-full object-cover transition-transform duration-500 group-hover:scale-105'
                            />
                        </div>

                        <!-- Content -->
                        <div class='flex flex-col flex-1 p-5 gap-3'>

                            <!-- Date -->
                            <time
                                datetime={post.data.pubDate.toISOString()}
                                class='text-xs text-muted-foreground'
                            >
                                {formatDate(post.data.pubDate)}
                            </time>

                            <!-- Title -->
                            <h2 class='text-base font-semibold text-foreground leading-snug group-hover:text-primary transition-colors'>
                                {post.data.title}
                            </h2>

                            <!-- Description -->
                            <p class='text-sm text-muted-foreground leading-relaxed line-clamp-3'>
                                {post.data.description}
                            </p>

                            <!-- Tags + read more -->
                            <div class='flex items-center justify-between gap-2 mt-auto pt-2 border-t border-border'>
                                <div class='flex flex-wrap gap-1.5'>
                                    {post.data.tags.slice(0, 2).map((tag) => (
                                        <span class='inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-accent text-accent-foreground'>
                                            {tag}
                                        </span>
                                    ))}
                                </div>
                                <span class='text-xs font-medium text-primary flex items-center gap-1 shrink-0'>
                                    Read more
                                    <svg xmlns='http://www.w3.org/2000/svg' class='size-3' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true'><path d='m9 18 6-6-6-6'/></svg>
                                </span>
                            </div>
                        </div>
                    </article>
                ))}
            </div>
        )}
    </section>

    <!-- CTA -->
    <section class='bg-accent/40 border-t border-border py-14'>
        <div class='container mx-auto px-4 text-center'>
            <h2 class='text-xl font-bold text-foreground mb-2'>Need a quote or have a question?</h2>
            <p class='text-muted-foreground text-sm mb-6 max-w-md mx-auto'>
                Our team responds within 1 business day.
            </p>
            <a
                href='/contact'
                class='inline-flex items-center gap-2 bg-primary text-primary-foreground font-semibold px-6 py-3 rounded-lg text-sm hover:bg-primary/90 transition-colors'
            >
                Get in Touch
                <svg xmlns='http://www.w3.org/2000/svg' class='size-4' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true'><path d='M5 12h14'/><path d='m12 5 7 7-7 7'/></svg>
            </a>
        </div>
    </section>
</Layout>
