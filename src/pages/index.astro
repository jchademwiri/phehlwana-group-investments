---
import { getCollection } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import StatsBar from '@/components/sections/StatsBar.astro';
import ContactCTA from '@/components/sections/ContactCTA.astro';
import Picture from '@/components/shared/Picture.astro';
import { serviceDivisions } from '@/data/navigation';

export const prerender = true;

// Pull 2 featured projects for the portfolio strip
const allProjects = await getCollection('projects', ({ data }) => data.published && data.featured);
const featuredProjects = allProjects
    .sort((a, b) => b.data.year - a.data.year)
    .slice(0, 3);

// Hero slides
const heroSlides = [
    {
        eyebrow: 'Welcome to Phehlwana Group Investments',
        headline: 'Construction and Maintenance',
        body: 'From new builds to routine upkeep, we keep your facilities safe, functional, and looking their best. Our experienced teams handle everything from structural work to emergency repairs.',
        image: '/images/hero/carousel-2.png',
        alt: 'Phehlwana Group construction team working on a building site in Pretoria',
    },
    {
        eyebrow: 'Welcome to Phehlwana Group Investments',
        headline: 'Safety Management and Plant Hire',
        body: 'We combine the logistical benefits of hiring specialised equipment with strict compliance to South African health and safety legislation - protecting your people, your assets, and your project timelines.',
        image: '/images/projects/project-04.jpeg',
        alt: 'Phehlwana Group TLB and plant hire equipment on a construction site',
    },
    {
        eyebrow: 'Welcome to Phehlwana Group Investments',
        headline: 'Cleaning and Waste Management',
        body: 'From commercial contract cleaning to hazardous waste disposal, we deliver hygienic, compliant, and environmentally responsible solutions for businesses of all sizes across South Africa.',
        image: '/images/projects/project-06.jpeg',
        alt: 'Phehlwana Group cleaning team in a commercial facility',
    },
];

// Service card images (4 exist, Security uses placeholder)
const serviceImages: Record<string, string> = {
    'Construction & Civil Engineering': '/images/services/service-construction.png',
    'Mechanical Engineering':           '/images/services/service-mechanical.png',
    'Cleaning & Waste Management':      '/images/services/service-cleaning.png',
    'Plant Hire':                       '/images/services/service-plant-hire.png',
    'Security':                         '/images/services/service-security.png',
};

const serviceDescriptions: Record<string, string> = {
    'Construction & Civil Engineering': 'New builds, renovations, road construction, road maintenance, and safety management - delivered to CIDB standards.',
    'Mechanical Engineering':           'Design, development, installation, and maintenance of mechanical systems and machinery for industrial and commercial clients.',
    'Cleaning & Waste Management':      'Commercial cleaning, industrial hygiene, hazardous waste handling, recycling, and compliant waste disposal.',
    'Plant Hire':                       'TLB, excavators, tipper trucks, water carts, bulldozers, generators, and tools - available for wet or dry hire.',
    'Security':                         'Manned guarding, access control, CCTV monitoring, risk assessment, event security, and site security.',
};

const values = [
    {
        icon: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>',
        title: 'Adaptable Solutions',
        body: 'We tailor our approach to each client\'s unique needs and project requirements.',
    },
    {
        icon: '<polyline points="20 6 9 17 4 12"/>',
        title: 'Uncompromising Quality',
        body: 'Every project is executed to the highest standards, on time and within budget.',
    },
    {
        icon: '<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>',
        title: 'Client-First Relationships',
        body: 'We build long-term partnerships based on trust, transparency, and results.',
    },
];

const trustItems = [
    { label: 'OHS Act Compliant',      icon: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>' },
    { label: 'NEM:WA Compliant',       icon: '<path d="M3 6h18M3 12h18M3 18h18"/>' },
    { label: '10+ Years in Business',  icon: '<rect width="18" height="18" x="3" y="4" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/>' },
    { label: '10 Full-Time Employees', icon: '<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/>' },
    { label: 'Level 1 BBBEE', icon: '<path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>' },
];
---

<Layout
    title='Phehlwana Group Investments | Construction, Engineering & Plant Hire Pretoria'
    description='Phehlwana Group Investments - trusted construction, civil engineering, mechanical services, cleaning, plant hire and security in Pretoria. Established 2015. Call 012 655 0284.'
>

    <!-- ── Hero ─────────────────────────────────────────────────────────────── -->
    <section class='relative overflow-hidden bg-neutral-950 text-white' aria-label='Hero'>
        <!-- Slides -->
        <div id='hero-slides' class='relative'>
            {heroSlides.map((slide, i) => (
                <div
                    class:list={[
                        'hero-slide absolute inset-0 transition-opacity duration-700',
                        i === 0 ? 'opacity-100 relative' : 'opacity-0 pointer-events-none',
                    ]}
                    data-slide={i}
                    aria-hidden={i !== 0 ? 'true' : undefined}
                >
                    <!-- Background image (WebP with fallback) -->
                    <div class='absolute inset-0'>
                        <Picture
                            src={slide.image}
                            alt=''
                            width={1920}
                            height={800}
                            loading={i === 0 ? 'eager' : 'lazy'}
                            decoding='async'
                            class='w-full h-full object-cover'
                        />
                        <div class='absolute inset-0 bg-neutral-950/65'></div>
                    </div>

                    <!-- Content -->
                    <div class='relative container mx-auto px-4 py-36 lg:py-44'>
                        <p class='text-sm font-semibold text-primary uppercase tracking-widest mb-4'>
                            {slide.eyebrow}
                        </p>
                        <h1 class='text-4xl sm:text-5xl lg:text-6xl font-bold leading-tight mb-6 max-w-2xl'>
                            {slide.headline}
                        </h1>
                        <p class='text-lg text-white/80 max-w-xl leading-relaxed mb-8'>
                            {slide.body}
                        </p>
                        <div class='flex flex-wrap gap-4'>
                            <a
                                href='/projects'
                                data-track="cta"
                                data-track-label="View Our Projects - Hero"
                                class='inline-flex items-center gap-2 bg-primary text-primary-foreground font-semibold px-6 py-3 rounded-lg text-sm hover:bg-primary/90 transition-colors'
                            >
                                View Our Projects
                                <svg xmlns='http://www.w3.org/2000/svg' class='size-4' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true'><path d='M5 12h14'/><path d='m12 5 7 7-7 7'/></svg>
                            </a>
                            <a
                                href='/services'
                                data-track="cta"
                                data-track-label="Our Services - Hero"
                                class='inline-flex items-center gap-2 bg-white/10 border border-white/30 text-white font-semibold px-6 py-3 rounded-lg text-sm hover:bg-white/20 transition-colors backdrop-blur-sm'
                            >
                                Our Services
                            </a>
                        </div>
                    </div>
                </div>
            ))}
        </div>

        <!-- Slide indicators -->
        <div class='absolute bottom-6 left-1/2 -translate-x-1/2 flex gap-2 z-10' role='tablist' aria-label='Hero slides'>
            {heroSlides.map((_, i) => (
                <button
                    type='button'
                    role='tab'
                    aria-selected={i === 0 ? 'true' : 'false'}
                    aria-label={`Slide ${i + 1}`}
                    data-slide-btn={i}
                    class:list={[
                        'slide-btn h-1.5 rounded-full transition-all duration-300',
                        i === 0 ? 'w-8 bg-white' : 'w-3 bg-white/40 hover:bg-white/70',
                    ]}
                ></button>
            ))}
        </div>
    </section>

    <!-- ── Stats bar ─────────────────────────────────────────────────────────── -->
    <StatsBar />

    <!-- ── About snapshot ───────────────────────────────────────────────────── -->
    <section class='container mx-auto px-4 py-16 lg:py-24'>
        <div class='grid lg:grid-cols-2 gap-12 items-center'>

            <!-- Left: copy -->
            <div data-animate>
                <p class='text-sm font-semibold text-primary uppercase tracking-widest mb-3'>
                    About Phehlwana Group Investments
                </p>
                <h2 class='text-3xl font-bold text-foreground mb-5 leading-tight'>
                    Building South Africa Since 2015
                </h2>
                <p class='text-muted-foreground leading-relaxed mb-4'>
                    Phehlwana Group Investments is a South African small-to-medium enterprise established
                    in 2015. Over the past decade, our highly professional and experienced team has built
                    a deep understanding of the construction, engineering, and facilities management
                    sectors - delivering quality results for government, corporate, and private clients
                    nationally.
                </p>
                <p class='text-muted-foreground leading-relaxed mb-8'>
                    Our business approach is built on a clear strategy: leverage local expertise, maintain
                    the highest standards of quality and safety, and develop lasting partnerships with our
                    clients. We don't just complete projects - we build relationships.
                </p>

                <!-- Values -->
                <ul class='space-y-4 mb-8'>
                    {values.map((v) => (
                        <li class='flex items-start gap-3'>
                            <div class='size-8 rounded-lg bg-primary/10 flex items-center justify-center shrink-0 mt-0.5'>
                                <svg xmlns='http://www.w3.org/2000/svg' class='size-4 text-primary' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true' set:html={v.icon}></svg>
                            </div>
                            <div>
                                <p class='text-sm font-semibold text-foreground'>{v.title}</p>
                                <p class='text-sm text-muted-foreground'>{v.body}</p>
                            </div>
                        </li>
                    ))}
                </ul>

                <a
                    href='/about'
                    class='inline-flex items-center gap-2 text-primary font-semibold text-sm hover:gap-3 transition-all'
                >
                    Learn More About Us
                    <svg xmlns='http://www.w3.org/2000/svg' class='size-4' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true'><path d='M5 12h14'/><path d='m12 5 7 7-7 7'/></svg>
                </a>
            </div>

            <!-- Right: image -->
            <div data-animate class='relative'>
                <div class='aspect-4/3 rounded-2xl overflow-hidden bg-accent shadow-lg'>
                    <Picture
                        src='/images/about-site.jpg'
                        alt='Phehlwana Group project site - construction work in progress'
                        width={800}
                        height={600}
                        loading='lazy'
                        decoding='async'
                        class='w-full h-full object-cover'
                    />
                </div>
                <!-- Floating badge -->
                <div class='absolute -bottom-4 -left-4 bg-primary text-primary-foreground rounded-xl px-5 py-3 shadow-lg'>
                    <p class='text-2xl font-bold'>10+</p>
                    <p class='text-xs text-primary-foreground/80 uppercase tracking-wide'>Years of Excellence</p>
                </div>
            </div>
        </div>
    </section>

    <!-- ── Services grid ─────────────────────────────────────────────────────── -->
    <section class='bg-accent/40 border-y border-border py-16 lg:py-24'>
        <div class='container mx-auto px-4'>
            <div class='text-center mb-12' data-animate>
                <p class='text-sm font-semibold text-primary uppercase tracking-widest mb-2'>Our Services</p>
                <h2 class='text-3xl font-bold text-foreground mb-4'>We Provide Best Services</h2>
                <p class='text-muted-foreground max-w-2xl mx-auto'>
                    At Phehlwana Group, we are committed to delivering excellence across every service
                    we provide. From large-scale civil engineering projects to daily cleaning contracts,
                    our teams bring the same dedication to quality, safety, and professionalism.
                </p>
            </div>

            <div class='grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6'>
                {serviceDivisions.map((service, i) => (
                    <article
                        class='group relative bg-card ring-1 ring-border rounded-xl overflow-hidden flex flex-col transition-shadow hover:shadow-lg'
                        data-animate
                    >
                        <a href={service.href} class='absolute inset-0 z-10' aria-label={`Learn more about ${service.division}`}/>

                        <!-- Image -->
                        <div class='aspect-video overflow-hidden bg-accent'>
                            <Picture
                                src={serviceImages[service.division] ?? '/images/placeholder.svg'}
                                alt=''
                                width={640}
                                height={360}
                                loading='lazy'
                                decoding='async'
                                class='w-full h-full object-cover transition-transform duration-500 group-hover:scale-105'
                            />
                        </div>

                        <!-- Content -->
                        <div class='flex flex-col flex-1 p-5 gap-2'>
                            <h3 class='text-base font-semibold text-foreground group-hover:text-primary transition-colors'>
                                {service.division}
                            </h3>
                            <p class='text-sm text-muted-foreground leading-relaxed flex-1'>
                                {serviceDescriptions[service.division]}
                            </p>
                            <span class='text-xs font-medium text-primary flex items-center gap-1 mt-2'>
                                Read More
                                <svg xmlns='http://www.w3.org/2000/svg' class='size-3' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true'><path d='m9 18 6-6-6-6'/></svg>
                            </span>
                        </div>
                    </article>
                ))}
            </div>

            <div class='text-center mt-10'>
                <a
                    href='/services'
                    class='inline-flex items-center gap-2 border border-border text-foreground font-semibold px-6 py-3 rounded-lg text-sm hover:bg-accent transition-colors'
                >
                    View All Services
                    <svg xmlns='http://www.w3.org/2000/svg' class='size-4' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true'><path d='M5 12h14'/><path d='m12 5 7 7-7 7'/></svg>
                </a>
            </div>
        </div>
    </section>

    <!-- ── Trust strip ───────────────────────────────────────────────────────── -->
    <section class='border-b border-border py-8 bg-background'>
        <div class='container mx-auto px-4'>
            <ul class='flex flex-wrap items-center justify-center gap-x-10 gap-y-4'>
                {trustItems.map((item) => (
                    <li class='flex items-center gap-2.5 text-sm text-muted-foreground'>
                        <div class='size-7 rounded-md bg-primary/10 flex items-center justify-center shrink-0'>
                            <svg xmlns='http://www.w3.org/2000/svg' class='size-3.5 text-primary' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true' set:html={item.icon}></svg>
                        </div>
                        <span class='font-medium text-foreground/80'>{item.label}</span>
                    </li>
                ))}
            </ul>
        </div>
    </section>

    <!-- ── Trusted Clients ──────────────────────────────────────────────────── -->
    <section class='container mx-auto px-4 py-12 lg:py-16'>
        <div class='text-center mb-8' data-animate>
            <h2 class='text-xl font-bold text-foreground mb-2'>
                Trusted By Leading Organisations
            </h2>
        </div>
        <div class='flex flex-wrap justify-center items-center gap-8 md:gap-12 opacity-70 grayscale hover:grayscale-0 transition-all duration-300' data-animate>
            <span class='text-xl font-bold text-foreground/60 whitespace-nowrap'>City of Tshwane</span>
            <span class='text-xl font-bold text-foreground/60 whitespace-nowrap'>Sanparks</span>
            <span class='text-xl font-bold text-foreground/60 whitespace-nowrap'>AgriSkills</span>
            <span class='text-xl font-bold text-foreground/60 whitespace-nowrap'>JB Levelling</span>
            <span class='text-xl font-bold text-foreground/60 whitespace-nowrap'>Magalies Water</span>
            <span class='text-xl font-bold text-foreground/60 whitespace-nowrap'>Civicon</span>
        </div>
    </section>

    <!-- ── Featured projects ─────────────────────────────────────────────────── -->
    {featuredProjects.length > 0 && (
        <section class='container mx-auto px-4 py-16 lg:py-24'>
            <div class='flex items-end justify-between mb-10' data-animate>
                <div>
                    <p class='text-sm font-semibold text-primary uppercase tracking-widest mb-2'>Our Work</p>
                    <h2 class='text-3xl font-bold text-foreground'>Featured Projects</h2>
                </div>
                <a
                    href='/projects'
                    class='hidden sm:inline-flex items-center gap-2 text-sm font-medium text-primary hover:gap-3 transition-all'
                >
                    View All Projects
                    <svg xmlns='http://www.w3.org/2000/svg' class='size-4' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true'><path d='M5 12h14'/><path d='m12 5 7 7-7 7'/></svg>
                </a>
            </div>

            <div class='grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6'>
                {featuredProjects.map((project) => (
                    <article class='group relative bg-card ring-1 ring-border rounded-xl overflow-hidden flex flex-col transition-shadow hover:shadow-lg' data-animate>
                        <a href={`/projects/${project.id}`} class='absolute inset-0 z-10' aria-label={`View project: ${project.data.title}`}/>
                        <div class='aspect-16/10 overflow-hidden bg-accent'>
                            <Picture
                                src={project.data.coverImage ?? '/images/placeholder.svg'}
                                alt=''
                                width={640}
                                height={400}
                                loading='lazy'
                                decoding='async'
                                class='w-full h-full object-cover transition-transform duration-500 group-hover:scale-105'
                            />
                        </div>
                        <div class='p-5 flex flex-col gap-2'>
                            <p class='text-xs text-muted-foreground'>{project.data.category} · {project.data.location}</p>
                            <h3 class='text-sm font-semibold text-foreground group-hover:text-primary transition-colors leading-snug'>
                                {project.data.title}
                            </h3>
                        </div>
                    </article>
                ))}
            </div>

            <div class='text-center mt-8 sm:hidden'>
                <a href='/projects' class='inline-flex items-center gap-2 text-sm font-medium text-primary'>
                    View All Projects
                    <svg xmlns='http://www.w3.org/2000/svg' class='size-4' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true'><path d='M5 12h14'/><path d='m12 5 7 7-7 7'/></svg>
                </a>
            </div>
        </section>
    )}

    <!-- ── CTA ───────────────────────────────────────────────────────────────── -->
    <ContactCTA
        heading='Ready to Get Started?'
        body='Contact us today for a free, no-obligation quote on any of our services. Our team responds within 1 business day.'
    />
</Layout>

<script>
    // ── Hero carousel ─────────────────────────────────────────────────────────
    const slides  = document.querySelectorAll<HTMLElement>('.hero-slide');
    const btns    = document.querySelectorAll<HTMLButtonElement>('.slide-btn');
    let current   = 0;
    let timer: ReturnType<typeof setInterval>;

    const goTo = (index: number) => {
        slides[current].classList.replace('opacity-100', 'opacity-0');
        slides[current].classList.add('pointer-events-none');
        slides[current].setAttribute('aria-hidden', 'true');
        btns[current].classList.replace('w-8', 'w-3');
        btns[current].classList.replace('bg-white', 'bg-white/40');
        btns[current].setAttribute('aria-selected', 'false');

        current = index;

        slides[current].classList.replace('opacity-0', 'opacity-100');
        slides[current].classList.remove('pointer-events-none');
        slides[current].removeAttribute('aria-hidden');
        btns[current].classList.replace('w-3', 'w-8');
        btns[current].classList.replace('bg-white/40', 'bg-white');
        btns[current].setAttribute('aria-selected', 'true');
    };

    const next = () => goTo((current + 1) % slides.length);

    const startTimer = () => { timer = setInterval(next, 5000); };
    const resetTimer = () => { clearInterval(timer); startTimer(); };

    btns.forEach((btn, i) => {
        btn.addEventListener('click', () => { goTo(i); resetTimer(); });
    });

    if (slides.length > 1) startTimer();
</script>
